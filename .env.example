# Anthropic API Key for Claude Vision analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Database path (defaults to ./storefront_analyzer.db)
DATABASE_PATH=./storefront_analyzer.db

# Optional: Upload directory (defaults to ./uploads)
UPLOADS_DIR=./uploads

# Optional: Reference guidelines directory (defaults to ./reference_guidelines)
GUIDELINES_DIR=./reference_guidelines

# Optional: Claude model to use (defaults to claude-haiku-4-5-20251001)
# Options:
#   - claude-haiku-4-5-20251001 (default): Faster, lower cost, good for high volume
#   - claude-sonnet-4-5-20250929: Higher precision, better for complex guidelines
MODEL_NAME=claude-haiku-4-5-20251001
